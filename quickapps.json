{
  "options": {
    "AutoCreateDatabase": true,
    "Cached": true
  },
  "apps": {
    "Blank": "",
    "Drupal": {
      "installer": "composer",
      "command": "create-project drupal/recommended-project \"%s\""
    },
    "Grav": {
      "version": "1.7.48",
      "url": "https://github.com/getgrav/grav/releases/download/1.7.48/grav-admin-v1.7.48.zip"
    },
    "Joomla": {
      "version": "5.2.1",
      "url": "https://downloads.joomla.org/cms/joomla5/5-2-1/Joomla_5-2-1-Stable-Full_Package.zip?format=zip"
    },
    "WordPress": {
      "url": "https://wordpress.org/latest.tar.gz"
    },
    "Laravel": {
      "composer": {
        "command": "create-project --prefer-dist laravel/laravel %s"
      },
      "installer": {
        "command": "call ..\\usr\\cmd\\create-project_laravel-installer.cmd %s"
      }
    },
    "CakePHP": {
      "installer": "composer",
      "command": "create-project --prefer-dist cakephp/app %s"
    }
  }
}
